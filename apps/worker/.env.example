# See root .env.example — this is the source of truth, loaded via
# dotenv-cli in this app's dev/start scripts. Listed here only as
# documentation of what apps/worker reads.
DATABASE_URL="postgresql://raas:raas@localhost:5432/raas?schema=public"
APP_DATABASE_URL="postgresql://raas_app:raas_app@localhost:5432/raas?schema=public"
REDIS_URL="redis://localhost:6379"
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET="raas-documents"
S3_ACCESS_KEY_ID="raas"
S3_SECRET_ACCESS_KEY="raas_minio_secret"
S3_FORCE_PATH_STYLE=true
EMBEDDING_PROVIDER=fake
OPENAI_API_KEY=""
FAKE_EMBEDDING_DELAY_MS=0
# Stuck-document sweep (docs/architecture.md §6.2) — defaults are 30 min
# threshold / 5 min sweep interval; STUCK_DOCUMENT_AUTO_RETRY is off by
# default (see sweep-stuck-documents.ts's doc comment for why).
STUCK_DOCUMENT_THRESHOLD_MS=1800000
STUCK_DOCUMENT_SWEEP_INTERVAL_MS=300000
STUCK_DOCUMENT_AUTO_RETRY=false
LOG_LEVEL=debug
NODE_ENV=development
