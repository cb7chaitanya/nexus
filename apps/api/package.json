{
  "name": "@raas/api",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "dotenv -e ../../.env -- tsx watch src/index.ts",
    "start": "dotenv -e ../../.env -- node dist/index.js",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist .turbo",
    "test": "dotenv -e ../../.env -- vitest run",
    "test:watch": "dotenv -e ../../.env -- vitest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.699.0",
    "@aws-sdk/s3-presigned-post": "^3.699.0",
    "@aws-sdk/s3-request-presigner": "^3.699.0",
    "@fastify/cookie": "^11.0.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^13.1.0",
    "@paddle/paddle-node-sdk": "^3.8.0",
    "@raas/auth": "workspace:*",
    "@raas/core": "workspace:*",
    "@raas/db": "workspace:*",
    "@raas/logger": "workspace:*",
    "@raas/metrics": "workspace:*",
    "@raas/observability": "workspace:*",
    "@raas/providers": "workspace:*",
    "@raas/rate-limit": "workspace:*",
    "@raas/shared": "workspace:*",
    "@raas/usage": "workspace:*",
    "@sentry/node": "^10.67.0",
    "argon2": "^0.41.1",
    "bullmq": "^5.80.5",
    "fastify": "^5.0.0",
    "gpt-tokenizer": "^3.4.0",
    "ioredis": "^5.4.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@raas/config": "workspace:*",
    "@types/node": "^20.14.0",
    "dotenv-cli": "^7.4.2",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^2.1.9"
  }
}
