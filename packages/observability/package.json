    "clean": "rm -rf dist .turbo",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {},
  "devDependencies": {
    "@raas/config": "workspace:*",
    "typescript": "^5.5.4",
    "vitest": "^2.1.9"
