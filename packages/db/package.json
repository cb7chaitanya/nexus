{
  "name": "@raas/db",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "prisma generate && tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint .",
    "typecheck": "prisma generate && tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist .turbo",
    "generate": "prisma generate",
    "migrate:dev": "dotenv -e ../../.env -- prisma migrate dev",
    "migrate:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "studio": "dotenv -e ../../.env -- prisma studio",
    "test": "dotenv -e ../../.env -- vitest run",
    "test:watch": "dotenv -e ../../.env -- vitest"
  },
  "dependencies": {
    "@prisma/client": "^5.18.0"
  },
  "devDependencies": {
    "@raas/config": "workspace:*",
    "dotenv-cli": "^7.4.2",
    "prisma": "^5.18.0",
    "typescript": "^5.5.4",
    "vitest": "^2.1.9"
  }
}
