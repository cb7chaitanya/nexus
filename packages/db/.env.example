# See root .env.example — this file documents what packages/db needs in
# isolation (e.g. for running `prisma migrate` directly from this package
# without the rest of the monorepo).
#
# DATABASE_URL: superuser/migration role, used only by the Prisma CLI.
# APP_DATABASE_URL: restricted role the PrismaClient/withTenantTransaction
# actually connect as — RLS is enforced against this role, not DATABASE_URL.
DATABASE_URL="postgresql://raas:raas@localhost:5432/raas?schema=public"
APP_DATABASE_URL="postgresql://raas_app:raas_app@localhost:5432/raas?schema=public"
