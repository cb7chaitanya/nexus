// Scope for this ticket: identity + tenant models only (User, Organization,
// OrganizationMember, Workspace). KnowledgeBase/Document/DocumentChunk/etc.
// land in later tickets — see docs/implementation-plan.md.
//
// Tenant isolation is enforced twice: Prisma-level `organizationId` filters
// (via withTenantTransaction, see src/tenant.ts) AND Postgres Row-Level
// Security as an independent backstop (see the RLS block appended by hand
// to this schema's migration — Prisma cannot express RLS policies natively).

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

// ───────────────────────── Identity ─────────────────────────
// Not tenant-scoped: a User has no organizationId of its own — membership
// (and therefore tenant association) is via OrganizationMember.

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String?
  name          String?
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  memberships   OrganizationMember[]
  sentInvites   OrganizationInvite[]
}

// ───────────────────────── Organization ─────────────────────────
// Not RLS-scoped: Organization *is* the tenant boundary, not tenant-scoped
// data — it has no organizationId to filter on. This means org
// name/slug/plan are visible to any DB connection regardless of tenant
// context; a deliberate, low-blast-radius scope boundary (no document
// content, credentials, or usage data lives here), not an oversight.
// See docs/decisions.md for the full reasoning.

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  plan      String   @default("free") // free | pro | enterprise
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members    OrganizationMember[]
  workspaces Workspace[]
  invites    OrganizationInvite[]
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
}

// ───────────────────────── Tenant-scoped: RLS-protected ─────────────────────────
// OrganizationMember and Workspace both carry organizationId and have RLS
// enabled + forced in this schema's migration, policy scoped to
// current_setting('app.current_org_id'). See withTenantTransaction
// (src/tenant.ts) — this is the only sanctioned way to query these tables
// with an org already selected.
//
// The userId-keyed "which orgs does this user belong to" follow-up flagged
// here previously (needed for login/GET /auth/me, no single org context
// yet) is resolved by the auth ticket's migration
// (20260715_add_self_membership_lookup): a second, SELECT-only permissive
// policy on OrganizationMember scoped by app.current_user_id, queried via
// withUserContext (src/tenant.ts) — never a general tenant bypass, only
// visibility into the calling user's own membership rows.

model OrganizationMember {
  id             String   @id @default(uuid())
  organizationId String
  userId         String
  role           OrgRole  @default(MEMBER)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
}

model Workspace {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  slug           String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, slug])
}

// ───────────────────────── Organization invites ─────────────────────────
// Deliberately NOT RLS-scoped, same reasoning as the ApiKey model
// architecture.md describes: authorization here is possession of a
// high-entropy token, not tenant membership — accepting an invite happens
// before the acceptor has any org context to scope a query by in the
// first place, the same chicken-and-egg problem OrganizationMember has,
// but the token itself is already the access-control mechanism, so a
// second RLS policy would add complexity without adding safety. Any
// future endpoint that lists invites for an org must filter by
// organizationId explicitly in application code — there is no RLS backstop
// on this table, by design.

model OrganizationInvite {
  id             String    @id @default(uuid())
  organizationId String
  email          String
  role           OrgRole   @default(MEMBER)
  hashedToken    String    @unique
  invitedById    String
  expiresAt      DateTime
  acceptedAt     DateTime?
  revokedAt      DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy    User         @relation(fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([organizationId])
}
