// Scope for this ticket: identity + tenant models only (User, Organization,
// OrganizationMember, Workspace). KnowledgeBase/Document/DocumentChunk/etc.
// land in later tickets — see docs/implementation-plan.md.
//
// Tenant isolation is enforced twice: Prisma-level `organizationId` filters
// (via withTenantTransaction, see src/tenant.ts) AND Postgres Row-Level
// Security as an independent backstop (see the RLS block appended by hand
// to this schema's migration — Prisma cannot express RLS policies natively).

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

// ───────────────────────── Identity ─────────────────────────
// Not tenant-scoped: a User has no organizationId of its own — membership
// (and therefore tenant association) is via OrganizationMember.

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String?
  name          String?
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  memberships       OrganizationMember[]
  sentInvites       OrganizationInvite[]
  uploadedDocuments Document[]
}

// ───────────────────────── Organization ─────────────────────────
// Not RLS-scoped: Organization *is* the tenant boundary, not tenant-scoped
// data — it has no organizationId to filter on. This means org
// name/slug/plan are visible to any DB connection regardless of tenant
// context; a deliberate, low-blast-radius scope boundary (no document
// content, credentials, or usage data lives here), not an oversight.
// See docs/decisions.md for the full reasoning.

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  plan      String   @default("free") // free | pro | enterprise
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members        OrganizationMember[]
  workspaces     Workspace[]
  invites        OrganizationInvite[]
  knowledgeBases KnowledgeBase[]
  documents      Document[]
  documentChunks DocumentChunk[]
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
}

// ───────────────────────── Tenant-scoped: RLS-protected ─────────────────────────
// OrganizationMember and Workspace both carry organizationId and have RLS
// enabled + forced in this schema's migration, policy scoped to
// current_setting('app.current_org_id'). See withTenantTransaction
// (src/tenant.ts) — this is the only sanctioned way to query these tables
// with an org already selected.
//
// The userId-keyed "which orgs does this user belong to" follow-up flagged
// here previously (needed for login/GET /auth/me, no single org context
// yet) is resolved by the auth ticket's migration
// (20260715_add_self_membership_lookup): a second, SELECT-only permissive
// policy on OrganizationMember scoped by app.current_user_id, queried via
// withUserContext (src/tenant.ts) — never a general tenant bypass, only
// visibility into the calling user's own membership rows.

model OrganizationMember {
  id             String   @id @default(uuid())
  organizationId String
  userId         String
  role           OrgRole  @default(MEMBER)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
}

model Workspace {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  slug           String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, slug])
}

// ───────────────────────── Organization invites ─────────────────────────
// Deliberately NOT RLS-scoped, same reasoning as the ApiKey model
// architecture.md describes: authorization here is possession of a
// high-entropy token, not tenant membership — accepting an invite happens
// before the acceptor has any org context to scope a query by in the
// first place, the same chicken-and-egg problem OrganizationMember has,
// but the token itself is already the access-control mechanism, so a
// second RLS policy would add complexity without adding safety. Any
// future endpoint that lists invites for an org must filter by
// organizationId explicitly in application code — there is no RLS backstop
// on this table, by design.

model OrganizationInvite {
  id             String    @id @default(uuid())
  organizationId String
  email          String
  role           OrgRole   @default(MEMBER)
  hashedToken    String    @unique
  invitedById    String
  expiresAt      DateTime
  acceptedAt     DateTime?
  revokedAt      DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy    User         @relation(fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

// ───────────────────────── Knowledge base / documents ─────────────────────────
// Both tenant-scoped: RLS enabled + forced, same tenant_isolation pattern
// as Workspace (missing_ok deliberately omitted — a query reaching either
// table without going through withTenantTransaction should error loudly,
// not silently return zero rows). Neither needs a self-lookup escape
// hatch like OrganizationMember's: every route that touches a KB or
// document requires the caller to assert an organizationId up front (see
// apps/api's requireMembership), so there's no chicken-and-egg "which org
// does this belong to" query to support.
//
// embeddingDim is fixed platform-wide for MVP (see @raas/shared's
// PLATFORM_EMBEDDING_DIM, enforced at the API validation layer, not by a
// CHECK constraint here) — pgvector requires a fixed column dimension per
// table, so mixing embedding models within one KB is a real engineering
// problem the platform doesn't support yet, not just a validation nicety.

model KnowledgeBase {
  id                String   @id @default(uuid())
  organizationId    String
  name              String
  embeddingProvider String // "openai" | "cohere" | ...
  embeddingModel    String // "text-embedding-3-small"
  embeddingDim      Int
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  documents    Document[]
  chunks       DocumentChunk[]

  @@index([organizationId])
}

// Lifecycle for this ticket: PENDING_UPLOAD -> QUEUED -> PROCESSING -> READY
// | FAILED. Extraction/chunking/embedding are not implemented yet (see
// docs/implementation-plan.md RAAS-19) — PROCESSING is a single catch-all
// state for now rather than the more granular EXTRACTING/CHUNKING/EMBEDDING
// split architecture.md's full proposal describes; that split can replace
// PROCESSING later without touching PENDING_UPLOAD/QUEUED/READY/FAILED.
enum DocumentStatus {
  PENDING_UPLOAD
  QUEUED
  PROCESSING
  READY
  FAILED
}

model Document {
  id              String         @id @default(uuid())
  organizationId  String
  knowledgeBaseId String
  fileName        String
  mimeType        String
  sizeBytes       Int
  storageKey      String         @unique // S3/R2 object key
  status          DocumentStatus @default(PENDING_UPLOAD)
  failureReason   String?
  uploadedById    String?
  createdAt       DateTime       @default(now())
  processedAt     DateTime?

  organization  Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  knowledgeBase KnowledgeBase   @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  uploadedBy    User?           @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  chunks        DocumentChunk[]

  @@index([organizationId])
  @@index([knowledgeBaseId, status])
}

// ───────────────────────── Document chunks ─────────────────────────
// Written by apps/worker, not apps/api — the ingestion pipeline's worker
// processes must apply the exact same RLS discipline as the API (set
// app.current_org_id via withTenantTransaction before every write), never
// a BYPASSRLS role. @raas/db's PrismaClient always connects as raas_app
// (see src/client.ts), which is created NOBYPASSRLS in
// infra/postgres/init.sql — this is structurally guaranteed, not just a
// convention worker code has to remember.
//
// embedding is `Unsupported("vector(n)")` because Prisma has no native
// pgvector type — it can be read via $queryRaw but not written through the
// typed client, so writes to it use $executeRaw explicitly (see
// apps/worker's embed-chunks processor). Nullable because chunk-text
// creates the row (content/position) before embed-chunks fills in the
// vector; a chunk with a null embedding is "chunked but not yet embedded,"
// a real intermediate state, not a bug.
//
// @@unique([documentId, chunkIndex]) is what makes chunk-text idempotent
// under retry: it upserts on this key instead of blindly inserting, so a
// worker crash-and-retry mid-chunking cannot produce a duplicate set of
// chunks for the same document (see docs/implementation-plan.md §1.1(d)).
//
// No vector index (HNSW) yet — retrieval doesn't exist as a feature until
// a later ticket, and building/tuning that index only matters once query
// performance is being measured against real data (see decisions.md ADR-2).
model DocumentChunk {
  id              String   @id @default(uuid())
  organizationId  String
  knowledgeBaseId String
  documentId      String
  chunkIndex      Int
  content         String
  tokenCount      Int
  pageNumber      Int?
  charStart       Int
  charEnd         Int
  embedding       Unsupported("vector(1536)")?
  createdAt       DateTime @default(now())

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  knowledgeBase KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  document      Document      @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, chunkIndex])
  @@index([organizationId])
}
