// Scope for this ticket: identity + tenant models only (User, Organization,
// OrganizationMember, Workspace). KnowledgeBase/Document/DocumentChunk/etc.
// land in later tickets — see docs/implementation-plan.md.
//
// Tenant isolation is enforced twice: Prisma-level `organizationId` filters
// (via withTenantTransaction, see src/tenant.ts) AND Postgres Row-Level
// Security as an independent backstop (see the RLS block appended by hand
// to this schema's migration — Prisma cannot express RLS policies natively).

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

// ───────────────────────── Identity ─────────────────────────
// Not tenant-scoped: a User has no organizationId of its own — membership
// (and therefore tenant association) is via OrganizationMember.

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String?
  name          String?
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  memberships       OrganizationMember[]
  sentInvites       OrganizationInvite[]
  createdApiKeys    ApiKey[]
  uploadedDocuments Document[]
  usageEvents       UsageEvent[]
  conversations     Conversation[]
}

// ───────────────────────── Organization ─────────────────────────
// Not RLS-scoped: Organization *is* the tenant boundary, not tenant-scoped
// data — it has no organizationId to filter on. This means org
// name/slug/plan are visible to any DB connection regardless of tenant
// context; a deliberate, low-blast-radius scope boundary (no document
// content, credentials, or usage data lives here), not an oversight.
// See docs/decisions.md for the full reasoning.

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  // free | pro | enterprise — billing-reconciliation-owned: written only by
  // the (not-yet-built) payment-webhook/billing-sync path, never by a
  // member-facing route. apps/api/src/routes/organizations.ts's PATCH
  // /organizations/:id — the only mutation route touching this model —
  // deliberately has no code path that can set this field, for any role;
  // see packages/shared/src/schemas/organizations.ts's updateOrganizationSchema.
  // Until that billing-sync path exists, this column only ever changes via
  // a direct DB write (a manual/support action), never through the API.
  plan      String   @default("free")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members        OrganizationMember[]
  workspaces     Workspace[]
  invites        OrganizationInvite[]
  apiKeys        ApiKey[]
  knowledgeBases KnowledgeBase[]
  documents      Document[]
  documentChunks DocumentChunk[]
  usageEvents    UsageEvent[]
  conversations  Conversation[]
  messages       Message[]
  usageLimit     OrganizationUsageLimit?
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
}

// ───────────────────────── Tenant-scoped: RLS-protected ─────────────────────────
// OrganizationMember and Workspace both carry organizationId and have RLS
// enabled + forced in this schema's migration, policy scoped to
// current_setting('app.current_org_id'). See withTenantTransaction
// (src/tenant.ts) — this is the only sanctioned way to query these tables
// with an org already selected.
//
// The userId-keyed "which orgs does this user belong to" follow-up flagged
// here previously (needed for login/GET /auth/me, no single org context
// yet) is resolved by the auth ticket's migration
// (20260715_add_self_membership_lookup): a second, SELECT-only permissive
// policy on OrganizationMember scoped by app.current_user_id, queried via
// withUserContext (src/tenant.ts) — never a general tenant bypass, only
// visibility into the calling user's own membership rows.

model OrganizationMember {
  id             String   @id @default(uuid())
  organizationId String
  userId         String
  role           OrgRole  @default(MEMBER)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
}

model Workspace {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  slug           String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, slug])
}

// ───────────────────────── Organization invites ─────────────────────────
// Deliberately NOT RLS-scoped, same reasoning as the ApiKey model
// architecture.md describes: authorization here is possession of a
// high-entropy token, not tenant membership — accepting an invite happens
// before the acceptor has any org context to scope a query by in the
// first place, the same chicken-and-egg problem OrganizationMember has,
// but the token itself is already the access-control mechanism, so a
// second RLS policy would add complexity without adding safety. Any
// future endpoint that lists invites for an org must filter by
// organizationId explicitly in application code — there is no RLS backstop
// on this table, by design.

model OrganizationInvite {
  id             String    @id @default(uuid())
  organizationId String
  email          String
  role           OrgRole   @default(MEMBER)
  hashedToken    String    @unique
  invitedById    String
  expiresAt      DateTime
  acceptedAt     DateTime?
  revokedAt      DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy    User         @relation(fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

// ───────────────────────── API keys ─────────────────────────
// RLS-scoped (see migration 20260718100000_add_apikey_rls) with TWO
// permissive policies, OR'd together by Postgres:
//   - "tenant_isolation": the standard organizationId = app.current_org_id
//     pattern every other tenant table uses — what the session-
//     authenticated management routes (POST/GET /organizations/:id/api-keys,
//     DELETE .../api-keys/:keyId) go through via withTenantTransaction,
//     same as every other route in this codebase.
//   - "api_key_hash_lookup": SELECT-only, scoped by a hash of the bearer
//     token itself (app.current_api_key_hash, set via withApiKeyLookup —
//     packages/db/src/tenant.ts) — what requireApiKeyAuth
//     (apps/api/src/plugins/api-key-auth.ts) uses to resolve organizationId
//     FROM the key, before any org context exists. This solves the same
//     chicken-and-egg problem OrganizationMember's self_membership_lookup
//     policy solves for session auth (20260715081815) — "possession of a
//     high-entropy value is itself the access grant" — just backed by RLS
//     now instead of a bypass.
//
// hashedKey is SHA-256 of the raw key, not argon2 — same reasoning as
// hashInviteToken (apps/api/src/lib/invites.ts): the raw key is
// high-entropy and machine-generated, never user-chosen, so it doesn't
// need argon2's computational hardening against brute force the way a
// human password does. The raw key is shown exactly once at creation and
// never stored; `prefix` (a short, non-secret leading slice of the raw
// key) is what the list endpoint shows afterward so a key can be
// identified without ever re-exposing the secret.
model ApiKey {
  id             String    @id @default(uuid())
  organizationId String
  name           String
  hashedKey      String    @unique
  prefix         String
  createdBy      String?
  lastUsedAt     DateTime?
  expiresAt      DateTime?
  revokedAt      DateTime?
  createdAt      DateTime  @default(now())

  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdByUser User?        @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([organizationId])
}

// ───────────────────────── Knowledge base / documents ─────────────────────────
// Both tenant-scoped: RLS enabled + forced, same tenant_isolation pattern
// as Workspace (missing_ok deliberately omitted — a query reaching either
// table without going through withTenantTransaction should error loudly,
// not silently return zero rows). Neither needs a self-lookup escape
// hatch like OrganizationMember's: every route that touches a KB or
// document requires the caller to assert an organizationId up front (see
// apps/api's requireMembership), so there's no chicken-and-egg "which org
// does this belong to" query to support.
//
// embeddingDim is fixed platform-wide for MVP (see @raas/shared's
// PLATFORM_EMBEDDING_DIM, enforced at the API validation layer, not by a
// CHECK constraint here) — pgvector requires a fixed column dimension per
// table, so mixing embedding models within one KB is a real engineering
// problem the platform doesn't support yet, not just a validation nicety.

// ACTIVE is the only status a KB is ever created in. DELETING is set by
// DELETE /kb/:id when the KB has more chunks than
// KB_DELETION_ASYNC_CHUNK_THRESHOLD (apps/api/src/env.ts) — deletion for a
// KB that large is handed off to an async worker job (see
// apps/api/src/lib/kb-cleanup.ts, apps/worker's
// cleanup-knowledge-base processor) rather than cascade-deleting
// potentially tens of thousands of rows and S3 objects inside one HTTP
// request. A KB in DELETING is treated as already gone by every read path
// (GET /kb, GET /kb/:id) even though its rows still exist until the
// worker finishes — DELETE's contract is "this is gone now," not "this
// will eventually be gone."
enum KnowledgeBaseStatus {
  ACTIVE
  DELETING
}

model KnowledgeBase {
  id                String              @id @default(uuid())
  organizationId    String
  name              String
  description       String?
  embeddingProvider String // "openai" | "cohere" | ...
  embeddingModel    String // "text-embedding-3-small"
  embeddingDim      Int
  status            KnowledgeBaseStatus @default(ACTIVE)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  documents     Document[]
  chunks        DocumentChunk[]
  conversations Conversation[]

  @@index([organizationId])
}

// Lifecycle for this ticket: PENDING_UPLOAD -> QUEUED -> PROCESSING -> READY
// | FAILED. Extraction/chunking/embedding are not implemented yet (see
// docs/implementation-plan.md RAAS-19) — PROCESSING is a single catch-all
// state for now rather than the more granular EXTRACTING/CHUNKING/EMBEDDING
// split architecture.md's full proposal describes; that split can replace
// PROCESSING later without touching PENDING_UPLOAD/QUEUED/READY/FAILED.
enum DocumentStatus {
  PENDING_UPLOAD
  QUEUED
  PROCESSING
  READY
  FAILED
  // Soft-delete only — see DELETE /documents/:id. The row itself is kept
  // (audit trail: who uploaded what, when, and when it was removed);
  // only its DocumentChunk rows (vectors) and its S3 object are actually
  // removed. Excluded from every listing (GET /kb/:id/documents, GET
  // /kb/:id's stats) but still fetchable by id (GET /documents/:id) —
  // that's the entire point of preserving the row.
  DELETED
}

model Document {
  id              String         @id @default(uuid())
  organizationId  String
  knowledgeBaseId String
  fileName        String
  mimeType        String
  sizeBytes       Int
  storageKey      String         @unique // S3/R2 object key
  status          DocumentStatus @default(PENDING_UPLOAD)
  failureReason   String?
  // Incremented on every POST /documents/:id/retry. Folded into the
  // ingestion flow's BullMQ jobIds (see apps/api/src/lib/ingestion-flow.ts)
  // so a retry's jobs never collide with the original (or a prior retry's)
  // now-terminal jobs still sitting in Redis — reusing a jobId BullMQ
  // already moved to a terminal state corrupts its internal bookkeeping
  // rather than cleanly re-running it. Also doubles as audit trail: how
  // many times has this document actually been retried.
  retryCount      Int            @default(0)
  uploadedById    String?
  createdAt       DateTime       @default(now())
  // Needed for stuck-job recovery (apps/worker's sweep-stuck-documents):
  // createdAt alone can't tell you how long a document has sat in its
  // CURRENT status — a document that spent hours in PENDING_UPLOAD before
  // recently becoming QUEUED shouldn't be flagged as stuck off its
  // original createdAt. Auto-updated on every status transition.
  updatedAt       DateTime       @updatedAt
  processedAt     DateTime?
  // Set exactly once, by DELETE /documents/:id — distinct from updatedAt
  // (which every status transition bumps) so "was this deleted, and when"
  // is unambiguous audit trail rather than inferred from status alone.
  deletedAt       DateTime?

  organization  Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  knowledgeBase KnowledgeBase   @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  uploadedBy    User?           @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  chunks        DocumentChunk[]

  @@index([organizationId])
  @@index([knowledgeBaseId, status])
}

// ───────────────────────── Document chunks ─────────────────────────
// Written by apps/worker, not apps/api — the ingestion pipeline's worker
// processes must apply the exact same RLS discipline as the API (set
// app.current_org_id via withTenantTransaction before every write), never
// a BYPASSRLS role. @raas/db's PrismaClient always connects as raas_app
// (see src/client.ts), which is created NOBYPASSRLS in
// infra/postgres/init.sql — this is structurally guaranteed, not just a
// convention worker code has to remember.
//
// embedding is `Unsupported("vector(n)")` because Prisma has no native
// pgvector type — it can be read via $queryRaw but not written through the
// typed client, so writes to it use $executeRaw explicitly (see
// apps/worker's embed-chunks processor). Nullable because chunk-text
// creates the row (content/position) before embed-chunks fills in the
// vector; a chunk with a null embedding is "chunked but not yet embedded,"
// a real intermediate state, not a bug.
//
// @@unique([documentId, chunkIndex]) is what makes chunk-text idempotent
// under retry: it upserts on this key instead of blindly inserting, so a
// worker crash-and-retry mid-chunking cannot produce a duplicate set of
// chunks for the same document (see docs/implementation-plan.md §1.1(d)).
//
// HNSW index (cosine ops) on embedding — see migration
// 20260717122000_add_document_chunk_hnsw_index. Prisma cannot express
// this natively (no `@@index` syntax for access-method/opclass), so it
// only exists as hand-written raw SQL in that migration, not here.
model DocumentChunk {
  id              String   @id @default(uuid())
  organizationId  String
  knowledgeBaseId String
  documentId      String
  chunkIndex      Int
  content         String
  tokenCount      Int
  pageNumber      Int?
  charStart       Int
  charEnd         Int
  embedding       Unsupported("vector(1536)")?
  createdAt       DateTime @default(now())

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  knowledgeBase KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  document      Document      @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, chunkIndex])
  @@index([organizationId])
}

// ───────────────────────── Usage metering ─────────────────────────
// Tenant-scoped (RLS enabled + forced, same tenant_isolation pattern as
// DocumentChunk) and append-only — never mutate a row after creation, never
// roll up a running counter in place under concurrent writes (see
// docs/architecture.md's UsageEvent notes). `metadata` carries the
// operation-specific numbers (token counts, model name, document/
// conversation id) rather than a first-class `quantity` column — every
// billable fact this ticket needs to record varies in shape by `type`,
// and a single untyped `quantity Int` would either be meaningless for
// some event types or force awkward encoding into it.
enum UsageEventType {
  CHAT_REQUEST
  CHAT_PROMPT_TOKENS
  CHAT_COMPLETION_TOKENS
  EMBEDDING_TOKENS
  DOCUMENT_PROCESSED
}

model UsageEvent {
  id             String         @id @default(uuid())
  organizationId String
  userId         String?
  type           UsageEventType
  metadata       Json           @default("{}")
  createdAt      DateTime       @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId, type, createdAt])
}

// ───────────────────────── Usage limits (quotas) ─────────────────────────
// Tenant-scoped (RLS enabled + forced, same tenant_isolation pattern as
// DocumentChunk/UsageEvent). One row per organization, created lazily on
// first override — an org with no row here runs on the platform-wide
// defaults read from apps/api's and apps/worker's env (see
// @raas/usage's getOrganizationDailyLimit), so this table only needs a
// row when an org's ceiling actually deviates from the default. Primary
// key is organizationId itself (one row per org, not a synthetic id) —
// same shape as a 1:1 config extension of Organization would take if
// Prisma allowed extending a model directly.
model OrganizationUsageLimit {
  organizationId           String   @id
  maxDocumentsPerDay       Int
  maxEmbeddingTokensPerDay Int
  maxChatTokensPerDay      Int
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// ───────────────────────── Chat memory ─────────────────────────
// Both tenant-scoped, RLS enabled + forced. Message denormalizes
// organizationId directly (reachable via conversationId -> Conversation,
// but every other tenant-scoped table in this schema — Document,
// DocumentChunk, KnowledgeBase — denormalizes organizationId directly
// rather than relying on a join for its RLS policy, specifically so the
// policy is a plain column comparison, not a correlated subquery through
// another table. Message follows that same, already-established pattern.
//
// Access is org-level only, matching every other resource in this
// schema (see architecture.md §7 "Document permissions" — MVP has no
// finer-grained ACL than org membership): any member of the organization
// can view or continue any conversation in that org, not just the one
// who created it.
model Conversation {
  id              String   @id @default(uuid())
  organizationId  String
  userId          String
  knowledgeBaseId String
  title           String?
  createdAt       DateTime @default(now())

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  knowledgeBase KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  messages      Message[]

  @@index([organizationId, createdAt])
}

enum MessageRole {
  USER
  ASSISTANT
}

model Message {
  id             String      @id @default(uuid())
  organizationId String
  conversationId String
  role           MessageRole
  // The clean, marker-stripped text — the same text already streamed to
  // the client, never the raw LLM output with internal [[chunk:id]]
  // markers still in it (see @raas/core's CitationMarkerFilter). This is
  // also what gets replayed as history into a future turn's prompt, so a
  // future turn never sees a raw marker either.
  content        String
  citations      Json        @default("[]")
  usageMetadata  Json?
  // clock_timestamp(), not now(): apps/api's chat route creates the USER
  // and ASSISTANT rows for one turn inside a single transaction, and
  // Postgres's now()/CURRENT_TIMESTAMP is frozen at transaction start —
  // both rows would get an IDENTICAL createdAt, making ORDER BY createdAt
  // unable to distinguish which came first within that turn. Verified
  // directly (empirically, not assumed): a value read from now() twice
  // inside one transaction with a real delay between the two reads came
  // back identical; clock_timestamp() read the same way correctly
  // advanced. See migration 20260717123000_use_clock_timestamp_for_message_createdat.
  createdAt      DateTime    @default(dbgenerated("clock_timestamp()"))

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([organizationId])
}
