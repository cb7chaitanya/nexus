# Template for docker-compose.prod.yml. Copy to .env.prod (gitignored),
# fill in every value below, then deploy with:
#
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d
#
# Every var with no default in docker-compose.prod.yml is marked required
# below (compose refuses to start with a clear error if it's missing —
# see the `${VAR:?...}` guards in that file). Vars with a sensible
# platform default are commented out here; uncomment to override.
# See DEPLOYMENT.md for the full explanation of each one.

# --- Postgres ---
POSTGRES_USER=raas
POSTGRES_PASSWORD=CHANGE_ME_superuser_password
POSTGRES_DB=raas
# Password for the restricted, non-superuser role the running application
# actually connects as (raas_app) — see infra/postgres/init.prod.sh and
# packages/db/src/client.ts. Must differ from POSTGRES_PASSWORD.
POSTGRES_APP_PASSWORD=CHANGE_ME_app_role_password
# Postgres-side statement/idle-transaction timeouts, applied as raas_app
# ROLE defaults (see infra/postgres/init.prod.sh) — only take effect on
# first container start against a FRESH volume; an already-initialized
# database needs these applied manually once (see DEPLOYMENT.md's
# "Database connection pool and timeouts" section for the exact command).
# DB_STATEMENT_TIMEOUT=30s
# DB_IDLE_IN_TRANSACTION_TIMEOUT=10s
# Prisma client-side connection pool sizing, injected into
# APP_DATABASE_URL's query string in docker-compose.prod.yml — PER
# CONTAINER, not per service: api and worker each get their own pool
# against the same Postgres max_connections (100, this image's unmodified
# default), and total connections scale with replica count (see
# API_REPLICAS/WORKER_REPLICAS below). See DEPLOYMENT.md's "Database
# connection pool and timeouts" section for the full sizing formula and
# worked examples before raising either of these or the replica counts.
# API_DB_CONNECTION_LIMIT=10
# API_DB_POOL_TIMEOUT_SECONDS=20
# WORKER_DB_CONNECTION_LIMIT=15
# WORKER_DB_POOL_TIMEOUT_SECONDS=20
# Horizontal scaling. Total DB connections used = (API_REPLICAS *
# API_DB_CONNECTION_LIMIT) + (WORKER_REPLICAS * WORKER_DB_CONNECTION_LIMIT)
# — keep this comfortably under Postgres's max_connections (100 by
# default), see DEPLOYMENT.md for worked examples. WARNING: api publishes
# a fixed host port (API_PORT); raising API_REPLICAS above 1 requires
# removing that published port and fronting api with a reverse proxy that
# load-balances across replicas instead (see docker-compose.prod.yml's
# top-of-file comment) — otherwise Docker fails to start with "port is
# already allocated". worker has no published port and scales out safely
# on its own.
# API_REPLICAS=1
# WORKER_REPLICAS=1

# --- Redis ---
REDIS_PASSWORD=CHANGE_ME_redis_password

# --- apps/api ---
# The one origin allowed to make credentialed cross-origin requests —
# your real web app's URL, never a wildcard.
WEB_ORIGIN=https://your-app.example.com
# Generate with: openssl rand -base64 48
SESSION_JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_48
# API_PORT=4000
# WEB_PORT=3000
# SESSION_TTL_SECONDS=604800
# Only needed if apps/web and apps/api are on different subdomains (e.g.
# web on app.example.com, api on api.app.example.com) — set to the
# shared parent (app.example.com in that example) or the session cookie
# won't be visible to apps/web's own server-side auth check. Leave unset
# if web/api share one host (reverse-proxied to one domain).
# SESSION_COOKIE_DOMAIN=app.example.com
# Hard per-request ceiling on completion output tokens — the real
# per-request cost backstop (see @raas/providers's OpenAIChatProvider).
# MAX_COMPLETION_TOKENS=1024
# How long SIGTERM/SIGINT waits for an in-progress chat SSE stream to
# finish before forcing exit (apps/api/src/lib/shutdown.ts). Must stay
# below the api service's stop_grace_period in docker-compose.prod.yml
# (30s) or Compose's own SIGKILL fires first — see DEPLOYMENT.md.
# API_SHUTDOWN_TIMEOUT_MS=25000

# --- "Sign in with Google" — optional, leave both unset to disable ---
# Authorized redirect URI on the Google Cloud OAuth client must be
# exactly <this deployment's public API URL>/auth/google/callback.
# GOOGLE_CLIENT_ID=CHANGE_ME_google_oauth_client_id
# GOOGLE_CLIENT_SECRET=CHANGE_ME_google_oauth_client_secret
# GOOGLE_REDIRECT_URI=https://CHANGE_ME_your_api_domain/auth/google/callback

# --- Paddle billing — optional, leave all unset to disable ---
# Paddle (Merchant of Record — works for India-based sellers, unlike
# Stripe). All three must be set together or not at all (see env.ts).
# Webhook/notification destination in the Paddle dashboard must point at
# https://CHANGE_ME_your_api_domain/billing/webhook, subscribed to
# subscription.created/subscription.updated/subscription.canceled.
# PADDLE_API_KEY=CHANGE_ME_paddle_api_key
# PADDLE_WEBHOOK_SECRET=CHANGE_ME_paddle_webhook_secret
# PADDLE_ENVIRONMENT=production
# PADDLE_PRO_PRICE_ID=CHANGE_ME_paddle_pro_price_id
# apps/web also needs, set to the SAME price id and a real client-side
# token (Paddle dashboard > Developer Tools > Authentication):
# NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=CHANGE_ME_paddle_client_token
# NEXT_PUBLIC_PADDLE_PRO_PRICE_ID=CHANGE_ME_paddle_pro_price_id

# --- Reverse proxy (infra/caddy/Caddyfile) — only used by the "proxy"
# Compose profile (`docker compose --profile proxy up -d`), never started
# by a plain `up -d`. Real domains, DNS already pointing at this host's
# public IP, before starting that profile — see DEPLOYMENT.md's
# "HTTPS / reverse proxy" section. WEB_ORIGIN above must be updated to
# `https://<APP_DOMAIN>` at the same time (CORS must match the real
# origin browsers will actually use).
# APP_DOMAIN=app.your-app.example
# API_DOMAIN=api.your-app.example

# --- Object storage ---
# No bundled/self-hosted object storage in this stack — point these at a
# real S3-compatible provider you've already provisioned (S3, R2, etc.).
# S3_FORCE_PATH_STYLE=false for real AWS S3 (true for R2 and most other
# S3-compatible providers). For Cloudflare R2 specifically: S3_ENDPOINT is
# https://<account_id>.r2.cloudflarestorage.com, S3_REGION=auto.
S3_BUCKET=CHANGE_ME_bucket_name
S3_ACCESS_KEY_ID=CHANGE_ME_s3_access_key
S3_SECRET_ACCESS_KEY=CHANGE_ME_s3_secret_key
S3_ENDPOINT=CHANGE_ME_s3_endpoint
# S3_REGION=us-east-1
# S3_FORCE_PATH_STYLE=true

# --- Providers ---
# "fake" is a real, documented provider (deterministic, offline, no cost)
# but must never be used for a real deployment — set both to "openai" and
# provide a real key.
EMBEDDING_PROVIDER=openai
LLM_PROVIDER=openai
OPENAI_API_KEY=CHANGE_ME_openai_api_key
# OPENAI_CHAT_MODEL=gpt-4o-mini
# LLM_PROVIDER=groq is a chat-completions-only alternative to "openai" —
# reuses OpenAIChatProvider against Groq's own OpenAI-compatible endpoint
# (see apps/api/src/lib/llm-provider.ts). Groq has no embeddings API, so
# EMBEDDING_PROVIDER must stay "openai" or "fake" even when this is set.
# GROQ_API_KEY=CHANGE_ME_groq_api_key
# GROQ_CHAT_MODEL=llama-3.3-70b-versatile

# --- Transactional email (apps/worker's send-email queue — currently
# just signup-verification OTP codes) ---
# "fake" logs instead of sending; never use it for a real deployment.
# Requires a Resend account + API key and a verified sending domain.
EMAIL_PROVIDER=resend
RESEND_API_KEY=CHANGE_ME_resend_api_key
EMAIL_FROM_ADDRESS="Nexus <noreply@CHANGE_ME_your_domain>"
# Signup OTP tuning (apps/api) — defaults are fine for most deployments.
# SIGNUP_OTP_TTL_SECONDS=600
# MAX_OTP_ATTEMPTS=5

# --- Rate limiting / cost controls (platform-wide defaults; per-org
# overrides live in the OrganizationUsageLimit table, not here) ---
# RATE_LIMIT_AUTH_MAX=10
# RATE_LIMIT_AUTH_WINDOW_SECONDS=60
# RATE_LIMIT_CHAT_ORG_RPM=30
# RATE_LIMIT_CHAT_USER_RPM=20
# RATE_LIMIT_CHAT_TOKEN_BUDGET_DAILY=200000
# RATE_LIMIT_INGESTION_ORG_RPM=20
# RATE_LIMIT_DOCUMENT_QUOTA_DAILY_DEFAULT=200
# RATE_LIMIT_EMBEDDING_TOKEN_BUDGET_DAILY_DEFAULT=2000000
# CHAT_HISTORY_MESSAGE_LIMIT=20
# KB_DELETION_ASYNC_CHUNK_THRESHOLD=5000

# --- apps/worker tuning (defaults are fine for most deployments) ---
# OPENAI_EMBEDDING_BATCH_SIZE=100
# WORKER_LOCK_DURATION_MS=30000
# WORKER_STALLED_INTERVAL_MS=30000
# STUCK_DOCUMENT_THRESHOLD_MS=1800000
# STUCK_DOCUMENT_SWEEP_INTERVAL_MS=300000
# STUCK_DOCUMENT_AUTO_RETRY=false
# Ceiling on Document.retryCount before a stuck document is left
# permanently FAILED instead of auto-retried again — only consulted when
# STUCK_DOCUMENT_AUTO_RETRY is on.
# STUCK_DOCUMENT_MAX_AUTO_RETRIES=3
# Per-document in-memory guardrail (extract-text.ts), distinct from and
# lower than the platform's accepted-upload ceiling. Multiplied by
# WORKER_EXTRACTION_CONCURRENCY for this worker's worst-case concurrent
# memory use — size both against this container's real memory limit.
# WORKER_MAX_DOCUMENT_BYTES=209715200
# Runtime RSS-based backpressure (extract-text) — the other half of the
# memory budget above, for when a parse's actual peak memory use exceeds
# the static concurrency x per-document-size estimate. See DEPLOYMENT.md.
# WORKER_MEMORY_RSS_LIMIT_BYTES=1610612736
# WORKER_MEMORY_BACKPRESSURE_DELAY_MS=5000
# Per-queue concurrency — processing is cheap (high concurrency is fine),
# extraction is memory-bound (see WORKER_MAX_DOCUMENT_BYTES above),
# embedding/kb-cleanup are I/O-bound against an external provider/S3,
# sweep is deliberately serialized.
# WORKER_PROCESSING_CONCURRENCY=10
# WORKER_EXTRACTION_CONCURRENCY=4
# WORKER_EMBEDDING_CONCURRENCY=2
# WORKER_SWEEP_CONCURRENCY=1
# WORKER_KB_CLEANUP_CONCURRENCY=2
# WORKER_DOCUMENT_CLEANUP_CONCURRENCY=10
# Generic per-job-attempt wall-clock ceiling (lib/job-timeout.ts) — the
# outermost backstop against a job hung well past any reasonable duration
# for its stage.
# WORKER_MAX_JOB_DURATION_MS=600000
# How long SIGTERM/SIGINT waits for active jobs to finish before forcing
# exit (lib/shutdown.ts). Must stay below the worker service's
# stop_grace_period in docker-compose.prod.yml (30s) — see DEPLOYMENT.md.
# WORKER_SHUTDOWN_TIMEOUT_MS=25000
# Bounds the startup Redis PING-or-fail check — a misconfigured REDIS_URL
# fails loudly within this window instead of hanging forever.
# WORKER_REDIS_CONNECT_TIMEOUT_MS=10000
# WORKER_HEALTH_PORT=3001

# --- apps/worker failure alerting (see
# apps/worker/src/lib/notifications/) — optional. Unset means no-op: no
# alerts sent, worker starts normally. Point this at a receiver (a Slack
# incoming webhook, PagerDuty Events API endpoint, a small relay function,
# etc.) to get a POSTed JSON event every time a job permanently exhausts
# its retries. ---
# ALERT_WEBHOOK_URL=
# ALERT_WEBHOOK_TIMEOUT_MS=5000

# --- shared ---
# LOG_LEVEL=info
# Error tracking (apps/api/src/lib/sentry.ts, apps/worker/src/lib/sentry.ts)
# — optional. Unset means no-op: captureException calls throughout both
# apps (the API error handler's unexpected-error path, worker job-failure
# handling, and both apps' uncaughtException/unhandledRejection handlers)
# go to NoopErrorTracker instead of a real tracker. Point this at a real
# Sentry project's DSN to start capturing crashes.
# SENTRY_DSN=
