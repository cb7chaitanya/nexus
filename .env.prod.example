# Template for docker-compose.prod.yml. Copy to .env.prod (gitignored),
# fill in every value below, then deploy with:
#
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d
#
# Every var with no default in docker-compose.prod.yml is marked required
# below (compose refuses to start with a clear error if it's missing —
# see the `${VAR:?...}` guards in that file). Vars with a sensible
# platform default are commented out here; uncomment to override.
# See DEPLOYMENT.md for the full explanation of each one.

# --- Postgres ---
POSTGRES_USER=raas
POSTGRES_PASSWORD=CHANGE_ME_superuser_password
POSTGRES_DB=raas
# Password for the restricted, non-superuser role the running application
# actually connects as (raas_app) — see infra/postgres/init.prod.sh and
# packages/db/src/client.ts. Must differ from POSTGRES_PASSWORD.
POSTGRES_APP_PASSWORD=CHANGE_ME_app_role_password

# --- Redis ---
REDIS_PASSWORD=CHANGE_ME_redis_password

# --- apps/api ---
# The one origin allowed to make credentialed cross-origin requests —
# your real web app's URL, never a wildcard.
WEB_ORIGIN=https://your-app.example.com
# Generate with: openssl rand -base64 48
SESSION_JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_48
# API_PORT=4000
# WEB_PORT=3000
# SESSION_TTL_SECONDS=604800

# --- Object storage ---
# Defaults below point at the bundled MinIO service. To use real S3/R2
# instead: delete the object-storage service from docker-compose.prod.yml,
# set S3_ENDPOINT to your provider's endpoint, S3_FORCE_PATH_STYLE=false
# for real AWS S3 (true for R2/MinIO), and put your provider's real
# credentials in S3_ACCESS_KEY_ID/S3_SECRET_ACCESS_KEY below.
S3_BUCKET=raas-documents
S3_ACCESS_KEY_ID=CHANGE_ME_s3_access_key
S3_SECRET_ACCESS_KEY=CHANGE_ME_s3_secret_key
# S3_ENDPOINT=http://object-storage:9000
# S3_REGION=us-east-1
# S3_FORCE_PATH_STYLE=true

# --- Providers ---
# "fake" is a real, documented provider (deterministic, offline, no cost)
# but must never be used for a real deployment — set both to "openai" and
# provide a real key.
EMBEDDING_PROVIDER=openai
LLM_PROVIDER=openai
OPENAI_API_KEY=CHANGE_ME_openai_api_key
# OPENAI_CHAT_MODEL=gpt-4o-mini

# --- Rate limiting / cost controls (platform-wide defaults; per-org
# overrides live in the OrganizationUsageLimit table, not here) ---
# RATE_LIMIT_AUTH_MAX=10
# RATE_LIMIT_AUTH_WINDOW_SECONDS=60
# RATE_LIMIT_CHAT_ORG_RPM=30
# RATE_LIMIT_CHAT_USER_RPM=20
# RATE_LIMIT_CHAT_TOKEN_BUDGET_DAILY=200000
# RATE_LIMIT_INGESTION_ORG_RPM=20
# RATE_LIMIT_DOCUMENT_QUOTA_DAILY_DEFAULT=200
# RATE_LIMIT_EMBEDDING_TOKEN_BUDGET_DAILY_DEFAULT=2000000
# CHAT_HISTORY_MESSAGE_LIMIT=20
# KB_DELETION_ASYNC_CHUNK_THRESHOLD=5000

# --- apps/worker tuning (defaults are fine for most deployments) ---
# OPENAI_EMBEDDING_BATCH_SIZE=100
# WORKER_LOCK_DURATION_MS=30000
# WORKER_STALLED_INTERVAL_MS=30000
# STUCK_DOCUMENT_THRESHOLD_MS=1800000
# STUCK_DOCUMENT_SWEEP_INTERVAL_MS=300000
# STUCK_DOCUMENT_AUTO_RETRY=false

# --- shared ---
# LOG_LEVEL=info
