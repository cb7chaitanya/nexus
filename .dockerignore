# Keep the Docker build context small and deterministic — everything here
# is either reproducible inside the build (node_modules, dist, .next) or
# irrelevant to a container image (git history, editor state, local env).

**/node_modules
**/dist
**/.next
**/.turbo
**/*.tsbuildinfo
.git
.github
.vscode
.idea
.DS_Store
**/.DS_Store

# Never bake local secrets into an image layer.
.env
.env.local
.env.*.local

docs
*.md
