# Single source of truth for local dev env vars. Copy to `.env` (gitignored)
# at the repo root. Every app loads this same file via `dotenv-cli` so there
# is exactly one place to keep DB/Redis config in sync.

NODE_ENV=development

# --- Postgres (packages/db) ---
# Matches docker-compose.yml. pgvector extension is created by
# infra/postgres/init.sql on first container start.
#
# DATABASE_URL is the superuser/migration role (raas) — used ONLY by the
# Prisma CLI (migrate/generate). It must never be what the running
# application connects as: raas is a Postgres superuser by default in this
# image, and superusers bypass Row-Level Security unconditionally,
# regardless of FORCE ROW LEVEL SECURITY. See docs/decisions.md.
DATABASE_URL="postgresql://raas:raas@localhost:5432/raas?schema=public"

# APP_DATABASE_URL is the restricted, non-superuser role (raas_app,
# created by infra/postgres/init.sql) that the actual PrismaClient at
# runtime connects as. This is the role RLS policies are actually enforced
# against.
APP_DATABASE_URL="postgresql://raas_app:raas_app@localhost:5432/raas?schema=public"

# --- Redis (apps/worker, future BullMQ/rate-limiting) ---
REDIS_URL="redis://localhost:6379"

# --- apps/api ---
API_PORT=4000
API_HOST=0.0.0.0
# CORS: the one origin apps/api accepts credentialed cross-origin
# requests from — never a wildcard, since this API uses cookie auth.
# See docs/cors-csrf-policy.md for the full CORS/CSRF decision.
WEB_ORIGIN="http://localhost:3000"

# HMAC secret for signing session JWTs (packages/auth). Dev-only value —
# generate a real high-entropy secret per environment in staging/prod
# (e.g. `openssl rand -base64 48`), never reuse this one.
SESSION_JWT_SECRET="dev-only-insecure-secret-change-me-00000000000000000000000000"
# 7 days, in seconds. Also used as the Redis session record's TTL — see
# apps/api/src/lib/session.ts.
SESSION_TTL_SECONDS=604800
# Only needed when apps/web and apps/api are deployed on different
# subdomains — see DEPLOYMENT.md / .env.prod.example. Not needed locally
# (both apps run on "localhost", just different ports — cookies aren't
# port-scoped).
# SESSION_COOKIE_DOMAIN=

# --- "Sign in with Google" (apps/api/src/routes/auth.ts) ---
# Fully optional — leave both unset and the app works exactly as before
# (password + email-OTP signup only), the /auth/google* routes simply
# aren't registered. To enable: create an OAuth 2.0 Client ID (Web
# application) in Google Cloud Console, with Authorized redirect URIs
# for every environment's <API_ORIGIN>/auth/google/callback — for local
# dev that's http://localhost:4000/auth/google/callback, matching
# GOOGLE_REDIRECT_URI's own default below.
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# GOOGLE_REDIRECT_URI="http://localhost:4000/auth/google/callback"

# --- Paddle billing (apps/api/src/routes/billing.ts) ---
# Fully optional, same "leave unset and it's simply not registered" shape
# as Google OAuth above — the app works with no billing at all until
# these are set. All three (API key, webhook secret, Pro price id) must be
# set together or not at all (see env.ts). Create a Paddle account
# (sandbox first — Paddle is a Merchant of Record, works for India-based
# sellers unlike Stripe), a Product + Price for the Pro tier, and a
# webhook/notification destination pointed at
# <API_ORIGIN>/billing/webhook subscribed to subscription.created/
# subscription.updated/subscription.canceled.
# PADDLE_API_KEY=""
# PADDLE_WEBHOOK_SECRET=""
# PADDLE_ENVIRONMENT="sandbox"
# PADDLE_PRO_PRICE_ID=""

# --- Object storage (apps/api document uploads) ---
# MinIO locally (see docker-compose.yml), S3/R2 in staging/prod — same AWS
# SDK v3 client code talks to both, only these values change.
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET="raas-documents"
S3_ACCESS_KEY_ID="raas"
S3_SECRET_ACCESS_KEY="raas_minio_secret"
# MinIO (and R2) need path-style addressing; real AWS S3 doesn't. Kept as
# an explicit flag rather than inferred from S3_ENDPOINT so switching to
# real S3 in prod is a one-line env change, not a code change.
S3_FORCE_PATH_STYLE=true

# --- Ingestion pipeline (apps/worker) / retrieval + chat (apps/api) ---
# "fake" is a real, documented EmbeddingProvider/LLMProvider
# (@raas/providers) — deterministic, offline, no cost — not just a test
# mock. Local dev/test default on purpose, so this repo works out of the
# box with no OpenAI key. Staging/prod must explicitly set
# EMBEDDING_PROVIDER=openai / LLM_PROVIDER=openai and a real OPENAI_API_KEY.
EMBEDDING_PROVIDER=fake
OPENAI_API_KEY=""
FAKE_EMBEDDING_DELAY_MS=0
LLM_PROVIDER=fake
OPENAI_CHAT_MODEL=gpt-4o-mini
FAKE_LLM_DELAY_MS=0

# --- Transactional email (apps/worker's send-email queue) ---
# "fake" logs the message instead of sending — same "real, documented,
# local-dev-default" status as EMBEDDING_PROVIDER/LLM_PROVIDER above.
# Staging/prod must set EMAIL_PROVIDER=resend plus a real RESEND_API_KEY
# and a verified EMAIL_FROM_ADDRESS.
EMAIL_PROVIDER=fake
RESEND_API_KEY=""
EMAIL_FROM_ADDRESS=""
FAKE_EMAIL_DELAY_MS=0

# --- Rate limiting (packages/rate-limit) ---
# Anti-credential-stuffing limit on POST /auth/login and POST /auth/signup
# (IP-based) — the ticket's own example is ~10/minute/IP; the checked-in
# .env sets this higher purely because every app.inject() test request
# shares one apparent IP, which would otherwise fail unrelated tests
# partway through a suite run. Set explicitly for a real deployment.
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_AUTH_WINDOW_SECONDS=60
# POST /kb/:id/chat: per-organization and per-user requests/minute, plus
# an organization-scoped daily token budget (checked before generation,
# via a peekLimit pre-flight — see apps/api/src/lib/rate-limit.ts).
RATE_LIMIT_CHAT_ORG_RPM=30
RATE_LIMIT_CHAT_USER_RPM=20
RATE_LIMIT_CHAT_TOKEN_BUDGET_DAILY=200000
# Ingestion path (POST /kb, POST /kb/:id/documents/presign, POST
# /documents/:id/complete): organization-scoped requests/minute, plus a
# daily document-processing quota (checked at /complete — the point where
# the pipeline's real embedding cost is actually triggered). Both the
# quota here and the token budget above are platform-wide defaults, used
# whenever an org has no OrganizationUsageLimit override row (see
# @raas/usage's getOrganizationDailyLimit).
RATE_LIMIT_INGESTION_ORG_RPM=20
RATE_LIMIT_DOCUMENT_QUOTA_DAILY_DEFAULT=200
# Daily embedding-token budget, checked before every OpenAI embeddings
# call (both chat's per-query embedding in apps/api and the ingestion
# pipeline's bulk embedding in apps/worker — see @raas/usage's
# withEmbeddingBudgetGuard). Read by both processes; set once.
RATE_LIMIT_EMBEDDING_TOKEN_BUDGET_DAILY_DEFAULT=2000000
# How many prior turns (user+assistant pairs) are loaded as conversation
# history and replayed into the chat prompt.
CHAT_HISTORY_MESSAGE_LIMIT=20

# --- apps/worker operational endpoints ---
# GET /health (see apps/worker/src/health-server.ts) — not the same port
# as API_PORT so both processes can run on one host without colliding.
WORKER_HEALTH_PORT=3001
WORKER_HEALTH_HOST=0.0.0.0
# Optional — an unset URL selects a no-op notifier (see
# apps/worker/src/lib/notifications/index.ts) instead of failing to
# start. Set to a real receiver URL to get job-failure webhook alerts.
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_TIMEOUT_MS=5000

# --- shared ---
LOG_LEVEL=debug
